# Dockerfile.controller — the deploy controller for the OTA e2e test.
#
# Stands in for the dev box / dalek controller: it runs colony's ansible
# (provision/orchestrate over SSH), enroll-rig.sh, and fleet.py (Mender
# Management API). It does NOT run Theia — it drives the board containers.
#
# The repos it needs (colony, theia, ground-station) are bind-mounted at run time
# by the compose file, so this image only bakes the toolchain (ansible, ssh,
# python, mender-artifact) + the CI SSH private key.
FROM debian:bookworm

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
        ansible openssh-client ca-certificates curl jq \
        python3 python3-pip \
        tar gzip zstd \
    && rm -rf /var/lib/apt/lists/*

# mender-artifact (the .mender packer build-artifact.sh shells out to). The static
# linux/amd64 binary from Mender's release bucket — pinned.
ARG MENDER_ARTIFACT_VER=3.11.2
RUN curl -fsSL "https://downloads.mender.io/repos/debian/pool/main/m/mender-artifact/mender-artifact_${MENDER_ARTIFACT_VER}-1%2Bdebian%2Bbookworm_amd64.deb" \
        -o /tmp/mender-artifact.deb \
    && (apt-get update && apt-get install -y /tmp/mender-artifact.deb || dpkg -i /tmp/mender-artifact.deb || true) \
    && rm -f /tmp/mender-artifact.deb /var/lib/apt/lists/* \
    && command -v mender-artifact && mender-artifact --version || echo "mender-artifact pending"

# CI SSH private key — reaches the board containers as root. Throwaway, baked into
# this throwaway image only.
RUN mkdir -p /root/.ssh
COPY keys/ci_ed25519 /root/.ssh/id_ed25519
RUN chmod 700 /root/.ssh && chmod 600 /root/.ssh/id_ed25519 \
    && printf 'Host *\n  StrictHostKeyChecking no\n  UserKnownHostsFile /dev/null\n' > /root/.ssh/config

WORKDIR /work
# The driver script is mounted/copied at run time; keep the container alive so the
# test harness can `exec` steps into it (mirrors how a human drives the flow).
CMD [ "sleep", "infinity" ]

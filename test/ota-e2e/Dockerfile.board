# Dockerfile.board — a Theia "rig" container for the OTA e2e test.
#
# Stands in for a physical board (rpi4 central / jetson compute) so the FULL
# provision -> enroll -> install -> update -> rollback flow runs hermetically in
# CI. It is a SYSTEMD container on purpose: the real flow installs systemd units
# (theia-supervisor, mender-authd, mender-updated, theia-tipc-bearer), so the test
# must exercise systemd, not a fake init. Run with --privileged + the cgroup mount
# (the compose file sets this) so systemd can boot.
#
# It starts EMPTY (no Theia binaries) — the controller pushes everything in via
# colony ansible, exactly like a real greenfield board. Only factory prerequisites
# are baked: the 4.x mender client, zstd, python3, TIPC + libcap tooling.
#
# NO sshd: on HOST networking two board containers can't both bind :22, and ansible
# reaches them via the `community.docker.docker` connection (docker exec) instead —
# the controller mounts the docker socket. Simpler, and no keys/ports to manage.
# ubuntu:22.04 (Jammy) — MUST match the build host's distro: `theia dist` links the
# FC binaries (per's grpc/protobuf/boost/absl closure, nm's nftables) against the
# build host's system .so's, which are Jammy's (libprotobuf.so.23, boost 1.74,
# grpc.so.10). A bookworm board has different .so versions → the FCs fail to start
# (exit 127, "libabsl_synchronization.so.20210324: cannot open"). Same-distro is the
# real-deploy contract; here the board image matches the builder.
FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# systemd as PID 1 + runtime prereqs + the FC runtime-lib closure (the .so's the
# dist .deb's binaries dynamically link: grpc/protobuf/boost/absl for per, nftables
# for nm, etc). Without these the supervisor's children exit 127 on a missing lib.
RUN apt-get update && apt-get install -y --no-install-recommends \
        systemd systemd-sysv dbus \
        sudo ca-certificates curl gnupg \
        python3 python3-minimal \
        iproute2 libcap2-bin tar gzip zstd \
        procps net-tools \
        libgrpc++1 libprotobuf23 \
        libboost-system1.74.0 libboost-random1.74.0 \
        libnftables1 libssl3 \
    && rm -rf /var/lib/apt/lists/*

# Mender 4.x client from Mender's apt repo (ubuntu/jammy) — matching colony's
# install-mender.yml; the server v4 deployments API needs the update/auth split.
RUN install -d /etc/apt/keyrings \
    && curl -fsSL https://downloads.mender.io/repos/debian/gpg \
         -o /etc/apt/trusted.gpg.d/mender.asc \
    && echo "deb [arch=amd64] https://downloads.mender.io/repos/debian ubuntu/jammy/stable main" \
         > /etc/apt/sources.list.d/mender.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends mender-update mender-auth \
    && rm -rf /var/lib/apt/lists/*

# systemd needs these for a container boot.
STOPSIGNAL SIGRTMIN+3
VOLUME [ "/sys/fs/cgroup" ]
CMD [ "/sbin/init" ]
